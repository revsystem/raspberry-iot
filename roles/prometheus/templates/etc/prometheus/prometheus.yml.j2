global:
  scrape_interval:     1m
  evaluation_interval: 1m


scrape_configs:
  - job_name: 'prometheus'

    static_configs:
      - targets: ['{{ prometheus_hostname }}:9090']

  - job_name: node
    static_configs:
      - targets: ['{{ prometheus_hostname }}:9100']

remote_write:
  - url: "http://{{ influxdb_hostname }}:8086/api/v1/prom/write?db=prometheus"
